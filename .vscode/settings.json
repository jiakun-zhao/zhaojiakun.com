{
  "json.schemas": [
    {
      "fileMatch": ["**/*.mdx.json"],
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "description": "Title.",
            "pattern": "\\S+"
          }
        }
      }
    }
  ],
  "explorer.fileNesting.patterns": {
    "*.mdx": "${capture}.mdx.*",
  }
}
