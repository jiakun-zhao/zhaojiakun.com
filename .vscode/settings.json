{
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "astro", // Enable .astro
        "typescript", // Enable .ts
        "typescriptreact" // Enable .tsx
    ],
    "unocss.disable": true,
    "explorer.fileNesting.patterns": {
        "*.jpg": "$(capture).jpg.avif, $(capture).jpg.webp",
        "*.jpeg": "$(capture).jpeg.avif, $(capture).jpeg.webp",
        "*.png": "$(capture).png.avif, $(capture).png.webp",
    },
    "cSpell.words": [
        "Cantarell",
        "Dynadot",
        "giscus",
        "micromessenger",
        "Naoelrie",
        "Neue",
        "Ortner",
        "Roboto",
        "Segoe",
        "Villar",
        "wechat",
        "mdast"
    ]
}
