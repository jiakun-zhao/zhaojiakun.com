{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/github/:match*",
      "destination": "https://api.github.com/:match*"
    },
    {
      "source": "/api/openai/:match*",
      "destination": "https://api.openai.com/v1/:match*"
    }
  ],
  "functions": {
    "api/netease-cloud-music/**/*.{js,ts}": {
      "includeFiles": "api/netease-cloud-music/_utils.{js,ts}"
    }
  },
  "regions": ["hkg1"]
}
